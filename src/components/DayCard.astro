---
import type { Day } from '../types';

interface Props {
  day: Day;
  /** Namespaces the collapsible panel's DOM id — a week number or a module slug. */
  week: number | string;
}

const { day, week } = Astro.props;

// Only show the toggle when there's genuinely more to reveal.
const hasMore = !!(day.details || day.steps.length || day.stuck || day.resources.length);
const panelId = `day-panel-${week}-${day.n}`;
---

<li class="rounded-[14px] border-2 border-ink bg-card shadow-block-sm" x-data="{ open: false }">
  <div class="flex flex-col gap-4 p-5 sm:flex-row">
    <div class="shrink-0">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl border-2 border-ink bg-paper-2 font-mono text-sm font-bold">
        D{day.n}
      </span>
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-3">
        <h3 class="font-display text-lg font-semibold">{day.topic}</h3>
        {
          day.time && (
            <span class="mt-0.5 shrink-0 rounded-full border border-ink/20 bg-paper-2 px-2 py-0.5 font-mono text-[0.65rem] font-semibold text-ink-2">
              {day.time}
            </span>
          )
        }
      </div>

      <dl class="mt-2 space-y-1.5 text-sm">
        <div class="flex gap-2">
          <dt class="w-14 shrink-0 font-mono text-xs uppercase tracking-wide text-ink-3">Learn</dt>
          <dd class="text-ink-2">{day.learn}</dd>
        </div>
        {
          day.build && (
            <div class="flex gap-2">
              <dt class="w-14 shrink-0 font-mono text-xs uppercase tracking-wide text-ink-3">Build</dt>
              <dd class="text-ink-2">{day.build}</dd>
            </div>
          )
        }
      </dl>

      <div class="mt-3 rounded-lg border-l-4 border-vermilion bg-vermilion/8 px-3 py-2">
        <span class="font-mono text-xs font-semibold uppercase tracking-wide text-vermilion-deep">Do it →</span>
        <p class="mt-0.5 text-sm">{day.assignment}</p>
      </div>

      {
        hasMore && (
          <>
            <button
              type="button"
              x-on:click="open = !open"
              x-bind:aria-expanded="open ? 'true' : 'false'"
              aria-controls={panelId}
              class="mt-3 inline-flex items-center gap-1.5 font-mono text-xs font-semibold uppercase tracking-wide text-ink-2 transition-colors hover:text-vermilion-deep"
            >
              <span x-text="open ? 'Hide details' : 'Details, steps & resources'">Details, steps &amp; resources</span>
              <svg
                class="h-3.5 w-3.5 transition-transform duration-200"
                x-bind:class="open && 'rotate-180'"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>

            <div
              id={panelId}
              x-show="open"
              x-cloak
              x-transition.origin.top
              role="region"
              aria-label={`More on ${day.topic}`}
              class="mt-4 space-y-4 border-t border-ink/15 pt-4"
            >
              {day.details && (
                <div>
                  <h4 class="font-mono text-xs uppercase tracking-wide text-ink-3">The idea</h4>
                  <p class="mt-1 text-sm leading-relaxed text-ink-2">{day.details}</p>
                </div>
              )}

              {day.steps.length > 0 && (
                <div>
                  <h4 class="font-mono text-xs uppercase tracking-wide text-ink-3">Build it, step by step</h4>
                  <ol class="mt-2 space-y-1.5">
                    {day.steps.map((s, i) => (
                      <li class="flex gap-2.5 text-sm">
                        <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-ink/25 bg-paper-2 font-mono text-[0.65rem] font-bold">
                          {i + 1}
                        </span>
                        <span class="text-ink-2">{s}</span>
                      </li>
                    ))}
                  </ol>
                </div>
              )}

              {day.stuck && (
                <div class="rounded-lg border-l-4 border-teal bg-teal/8 px-3 py-2">
                  <span class="font-mono text-xs font-semibold uppercase tracking-wide text-teal-deep">Stuck?</span>
                  <p class="mt-0.5 text-sm text-ink-2">{day.stuck}</p>
                </div>
              )}

              {day.resources.length > 0 && (
                <div>
                  <h4 class="font-mono text-xs uppercase tracking-wide text-ink-3">Go deeper</h4>
                  <ul class="mt-2 space-y-2">
                    {day.resources.map((r) => (
                      <li>
                        <a
                          href={r.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="group flex items-start gap-2 text-sm"
                        >
                          <span class="mt-0.5 text-vermilion" aria-hidden="true">
                            ↗
                          </span>
                          <span class="text-ink-2 underline-offset-4 group-hover:text-vermilion-deep group-hover:underline">
                            {r.label}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </>
        )
      }
    </div>
  </div>
</li>
