---
interface Props {
  tech: string;
}
const { tech } = Astro.props;

// Static class strings so Tailwind's scanner keeps them.
const map: Record<string, string> = {
  HTML: 'border-vermilion/40 bg-vermilion/10 text-vermilion-deep',
  CSS: 'border-teal/40 bg-teal/10 text-teal-deep',
  JavaScript: 'border-honey-deep/45 bg-honey/20 text-honey-deep',
  'Tailwind CSS': 'border-teal/40 bg-teal/10 text-teal-deep',
  'Alpine.js': 'border-plum/40 bg-plum/10 text-plum',
  jQuery: 'border-ink/30 bg-ink/5 text-ink-2',
  // Foundation-track tech
  Terminal: 'border-ink/30 bg-ink/5 text-ink-2',
  Bash: 'border-ink/30 bg-ink/5 text-ink-2',
  Git: 'border-vermilion/40 bg-vermilion/10 text-vermilion-deep',
  GitHub: 'border-ink/30 bg-ink/5 text-ink-2',
  TypeScript: 'border-teal/40 bg-teal/10 text-teal-deep',
  React: 'border-teal/40 bg-teal/10 text-teal-deep',
  'Node.js': 'border-teal/40 bg-teal/10 text-teal-deep',
  Express: 'border-ink/30 bg-ink/5 text-ink-2',
  SQL: 'border-plum/40 bg-plum/10 text-plum',
  PostgreSQL: 'border-plum/40 bg-plum/10 text-plum',
  Supabase: 'border-teal/40 bg-teal/10 text-teal-deep',
  Vite: 'border-honey-deep/45 bg-honey/20 text-honey-deep',
  'LLM APIs': 'border-vermilion/40 bg-vermilion/10 text-vermilion-deep',
  AI: 'border-vermilion/40 bg-vermilion/10 text-vermilion-deep',
  n8n: 'border-plum/40 bg-plum/10 text-plum',
  'No-code': 'border-honey-deep/45 bg-honey/20 text-honey-deep',
  Freelancing: 'border-honey-deep/45 bg-honey/20 text-honey-deep',
};
const cls = map[tech] ?? 'border-ink/25 bg-ink/5 text-ink-2';
---

<span
  class:list={[
    'inline-flex items-center rounded-md border px-2 py-0.5 font-mono text-[0.68rem] font-semibold',
    cls,
  ]}
>
  {tech}
</span>
