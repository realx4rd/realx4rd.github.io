---
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: cls = '' } = Astro.props;
---

<!-- Building blocks of the web, being assembled. -->
<svg
  width={size}
  height={size}
  viewBox="0 0 30 30"
  fill="none"
  class={cls}
  aria-hidden="true"
  role="img"
>
  <rect x="2.2" y="16.5" width="11.3" height="11.3" rx="2.5" fill="#0f6f63" stroke="#21160d" stroke-width="2" />
  <rect x="16.5" y="16.5" width="11.3" height="11.3" rx="2.5" fill="#e6a91d" stroke="#21160d" stroke-width="2" />
  <rect x="9.35" y="2.2" width="11.3" height="11.3" rx="2.5" fill="#d63c11" stroke="#21160d" stroke-width="2" />
</svg>
