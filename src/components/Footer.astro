---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const cols = [
  {
    heading: 'Become a freelancer',
    links: [
      { href: '/start-here', label: 'Start here' },
      { href: '/foundation', label: 'Year 1 — The Foundation' },
      { href: '/journey', label: 'The 4-year journey' },
      { href: '/resources', label: 'Resources' },
    ],
  },
  {
    heading: 'The 12-week course',
    links: [
      { href: '/roadmap', label: 'Course roadmap' },
      { href: '/weeks/0', label: 'Week 0 — Launch Pad' },
      { href: '/assignments', label: 'Assignments' },
      { href: '/how-it-works', label: 'How it works' },
    ],
  },
];
---

<footer class="mt-24 border-t-2 border-ink bg-paper-2">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5">
          <Logo />
          <span class="font-display text-lg font-semibold tracking-tight">Click &amp; Learn Academy</span>
        </a>
        <p class="mt-4 max-w-sm text-pretty text-sm leading-relaxed text-ink-2">
          A free, non-profit academy that takes complete beginners from zero to shipping
          real, responsive, interactive websites — in three self-paced months.
        </p>
        <p class="mt-4 inline-flex items-start gap-2 rounded-lg border border-ink/15 bg-card px-3 py-2 font-mono text-xs leading-relaxed text-ink-2">
          <span aria-hidden="true">▲</span>
          <span>This very site is built with Astro&nbsp;+&nbsp;Tailwind&nbsp;+&nbsp;Alpine — the
          stack you'll learn here.</span>
        </p>
      </div>

      {
        cols.map((col) => (
          <nav aria-label={col.heading}>
            <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-ink-3">{col.heading}</h2>
            <ul class="mt-3 space-y-2">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-ink underline-offset-4 hover:text-vermilion-deep hover:underline">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-ink/15 pt-6 text-xs text-ink-2 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Click &amp; Learn Academy · Free forever · Made for learners.</p>
      <p class="font-mono">Click, build, ship.</p>
    </div>
  </div>
</footer>
