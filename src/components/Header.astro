---
import Logo from './Logo.astro';

const nav = [
  { href: '/roadmap', label: 'Roadmap' },
  { href: '/assignments', label: 'Assignments' },
  { href: '/how-it-works', label: 'How it works' },
  { href: '/resources', label: 'Resources' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header
  x-data="{ open: false }"
  class="sticky top-0 z-50 border-b-2 border-ink bg-paper/85 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2.5" aria-label="Click & Learn Academy — home">
      <Logo />
      <span class="leading-none">
        <span class="block font-display text-lg font-semibold tracking-tight">Click &amp; Learn</span>
        <span class="block font-mono text-[0.62rem] uppercase tracking-[0.22em] text-ink-2">Academy</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-paper-2',
              isActive(item.href) ? 'text-vermilion-deep' : 'text-ink',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/weeks/0"
        class="ml-2 inline-flex items-center gap-1.5 rounded-lg border-2 border-ink bg-vermilion px-3.5 py-2 text-sm font-semibold text-white shadow-block-sm transition-transform hover:-translate-y-0.5 active:translate-y-0 active:shadow-none"
      >
        Start free <span aria-hidden="true">→</span>
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border-2 border-ink bg-card shadow-block-sm md:hidden"
      x-on:click="open = !open"
      x-bind:aria-expanded="open.toString()"
      aria-controls="mobile-nav"
      aria-label="Toggle menu"
    >
      <svg x-show="!open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="7" x2="21" y2="7" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="17" x2="21" y2="17" />
      </svg>
      <svg x-show="open" x-cloak width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
        <line x1="5" y1="5" x2="19" y2="19" /><line x1="19" y1="5" x2="5" y2="19" />
      </svg>
    </button>
  </div>

  <!-- Mobile panel -->
  <nav
    id="mobile-nav"
    x-show="open"
    x-cloak
    x-transition.origin.top
    class="border-t-2 border-ink bg-card md:hidden"
    aria-label="Primary"
  >
    <div class="mx-auto max-w-6xl px-4 py-3 sm:px-6">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'block rounded-lg px-3 py-2.5 text-base font-medium',
              isActive(item.href) ? 'bg-paper-2 text-vermilion-deep' : 'text-ink hover:bg-paper-2',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/weeks/0"
        class="mt-1 block rounded-lg border-2 border-ink bg-vermilion px-3 py-2.5 text-center text-base font-semibold text-white shadow-block-sm"
      >
        Start free →
      </a>
    </div>
  </nav>
</header>
