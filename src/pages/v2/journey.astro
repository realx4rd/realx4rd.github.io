---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { years, milestones, totalFoundationHours } from '../../data/journey';
---

<BaseLayout
  title="The Journey"
  description="The multi-year path from complete beginner to a thriving IT freelancer: Year 1 builds a deep foundation and lands your first client; Years 2–4 specialize, scale, and build authority and income."
>
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="grid-paper border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
      <p class="reveal inline-flex items-center gap-2 rounded-full border-2 border-ink bg-card px-3 py-1 font-mono text-xs font-semibold tracking-wide shadow-block-sm">
        <span class="h-2 w-2 rounded-full bg-vermilion"></span>
        THE LONG GAME
      </p>
      <h1 class="reveal mt-5 max-w-3xl text-balance text-4xl font-semibold leading-[1.04] tracking-tight sm:text-5xl" style="animation-delay:.05s">
        Beginner today. <span class="marker-underline">Competitor</span> in a couple of years.
      </h1>
      <p class="reveal mt-5 max-w-2xl text-pretty text-lg text-ink-2" style="animation-delay:.1s">
        Nobody becomes a sought-after freelancer overnight — but the path is clear and it
        compounds. Year 1 makes you genuinely skilled and lands your first client. Each year
        after, you specialize, scale, and earn more. Here's the whole map.
      </p>
      <div class="reveal mt-7 flex flex-wrap gap-3" style="animation-delay:.15s">
        <a
          href="/v2"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-vermilion px-5 py-3 font-semibold text-white shadow-block transition-transform hover:-translate-y-0.5 active:translate-y-0 active:shadow-block-sm"
        >
          Open Year 1 — The Foundation <span aria-hidden="true">→</span>
        </a>
        <a
          href="/v2/start-here"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-card px-5 py-3 font-semibold shadow-block-sm transition-transform hover:-translate-y-0.5"
        >
          Start here
        </a>
      </div>
    </div>
  </section>

  <!-- ── The four years ───────────────────────────────────────────────── -->
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <ol class="space-y-5">
      {
        years.map((y) => (
          <li class="relative">
            <div
              class:list={[
                'overflow-hidden rounded-[14px] border-2 border-ink',
                y.detailed ? 'bg-card shadow-block' : 'bg-paper-2 shadow-block-sm',
              ]}
            >
              <div class="flex items-stretch">
                <div
                  class="flex w-16 shrink-0 items-center justify-center sm:w-20"
                  style={`background:${y.hex}`}
                >
                  <span class="font-display text-2xl font-bold text-white sm:text-3xl">Y{y.year}</span>
                </div>
                <div class="min-w-0 flex-1 p-5 sm:p-6">
                  <div class="flex flex-wrap items-center gap-2">
                    <h2 class="font-display text-xl font-semibold sm:text-2xl">{y.name}</h2>
                    {y.detailed ? (
                      <span class="rounded-full border-2 border-ink bg-honey px-2 py-0.5 font-mono text-[0.62rem] font-bold">★ BUILT NOW</span>
                    ) : (
                      <span class="rounded-full border border-ink/25 bg-card px-2 py-0.5 font-mono text-[0.62rem] font-semibold text-ink-3">preview</span>
                    )}
                    <span class="ml-auto rounded-md border border-ink/20 bg-paper px-2 py-0.5 font-mono text-[0.65rem] font-semibold text-ink-2">{y.targetIncome}</span>
                  </div>
                  <p class="mt-1 text-pretty text-ink-2">{y.tagline}</p>
                  <ul class="mt-3 grid gap-1.5 sm:grid-cols-2">
                    {y.outcomes.map((o) => (
                      <li class="flex items-start gap-2 text-sm">
                        <span class="mt-0.5 shrink-0 text-teal-deep" aria-hidden="true">✓</span>
                        <span class={y.detailed ? '' : 'text-ink-2'}>{o}</span>
                      </li>
                    ))}
                  </ul>
                  {y.detailed && (
                    <a
                      href="/v2"
                      class="mt-4 inline-flex items-center gap-1.5 font-semibold text-vermilion-deep underline-offset-4 hover:underline"
                    >
                      Explore all 10 phases (≈{totalFoundationHours}h) <span aria-hidden="true">→</span>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </li>
        ))
      }
    </ol>
    <p class="mt-6 text-center font-mono text-xs text-ink-3">
      Years 2–4 are a preview of the climb — Year 1 is fully built and ready to start.
    </p>
  </div>

  <!-- ── Milestone ladder ─────────────────────────────────────────────── -->
  <section class="border-y-2 border-ink bg-ink text-paper">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <div class="text-center">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-honey">Climb the ladder</p>
        <h2 class="mt-2 text-balance text-3xl font-semibold tracking-tight text-paper sm:text-4xl">
          Zero → your first $1k month
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-pretty text-paper/80">
          Behavioral checkpoints, not vague vibes. Each rung is a thing you <em>did</em> —
          celebrate them. Speed to the first dollar is what separates earners from quitters.
        </p>
      </div>
      <ol class="mt-10 space-y-2.5">
        {
          milestones.map((m, i) => (
            <li
              class:list={[
                'flex items-center gap-4 rounded-xl border-2 px-4 py-3',
                m.big ? 'border-honey bg-honey/15' : 'border-paper/15 bg-paper/5',
              ]}
            >
              <span
                class:list={[
                  'inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border-2 font-mono text-xs font-bold',
                  m.big ? 'border-honey bg-honey text-ink' : 'border-paper/25 bg-paper/10 text-paper/80',
                ]}
              >
                {i + 1}
              </span>
              <span class:list={['text-sm sm:text-base', m.big ? 'font-semibold text-paper' : 'text-paper/85']}>
                {m.label}
              </span>
              {m.big && <span class="ml-auto font-mono text-[0.62rem] uppercase tracking-wide text-honey">milestone</span>}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-16 text-center sm:px-6">
    <h2 class="mx-auto max-w-2xl text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
      The best time to start was a year ago. The second best is today.
    </h2>
    <a
      href="/v2/start-here"
      class="mt-7 inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-vermilion px-6 py-3.5 text-lg font-semibold text-white shadow-block transition-transform hover:-translate-y-0.5 active:translate-y-0 active:shadow-block-sm"
    >
      Start here <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
