---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pace, totalFoundationHours } from '../../data/journey';

const setup = [
  { n: 1, tool: 'A code editor', what: 'Install VS Code + the Prettier and Live Server extensions.', icon: '⌨' },
  { n: 2, tool: 'A GitHub account', what: 'Free. This is your portfolio, backup, and résumé in one.', icon: '🐙' },
  { n: 3, tool: 'A browser + DevTools', what: 'Chrome or Firefox. You already have it — learn to inspect with it.', icon: '🔍' },
];

const firstActions = [
  {
    t: 'Pick your pace and your finish line',
    d: 'Decide how many hours a week you can really give this, and circle your "Go Pro" date from the table above. Write it down where you study.',
  },
  {
    t: 'Set up your workshop (Week 0)',
    d: 'Work through Launch Pad: editor, terminal, Git, GitHub, DevTools, and your AI ground rules. ~7 hours, no pressure to "get code right" yet.',
    href: '/v2/weeks/0',
    cta: 'Open Week 0 — Launch Pad',
  },
  {
    t: 'Open Year 1 and start Phase 0',
    d: 'The Foundation lays out all 10 phases in order. Begin at the top and move down one item at a time — every item ships something.',
    href: '/v2',
    cta: 'Open Year 1 — The Foundation',
  },
];

const loop = [
  { k: '~20m', t: 'Learn', d: 'One concept from a hand-picked free resource. Hard cap — no binge-watching.' },
  { k: '~35m', t: 'Build along', d: 'Follow a guided demo so the idea clicks in your hands.' },
  { k: '~35m', t: 'Build alone', d: 'The same idea on a blank page, in your own words. This is where it sticks.' },
  { k: '↗', t: 'Commit & ship', d: 'Push to GitHub. Deploy real projects. Add a monetization action.' },
];
---

<BaseLayout
  title="Start Here"
  description="Your first hour on the path from beginner to earning IT freelancer: pick your pace, set up your workshop, and take your first three actions."
>
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="grid-paper border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
      <p class="reveal inline-flex items-center gap-2 rounded-full border-2 border-ink bg-card px-3 py-1 font-mono text-xs font-semibold tracking-wide shadow-block-sm">
        <span class="h-2 w-2 rounded-full bg-vermilion"></span>
        NO SIGNUP · NO PAYMENT · OPEN YOUR EDITOR AND GO
      </p>
      <h1 class="reveal mt-5 max-w-3xl text-balance text-4xl font-semibold leading-[1.04] tracking-tight sm:text-5xl" style="animation-delay:.05s">
        Your first hour as a <span class="marker-underline">future freelancer.</span>
      </h1>
      <p class="reveal mt-5 max-w-2xl text-pretty text-lg text-ink-2" style="animation-delay:.1s">
        You don't need to buy anything or be "technical." You need a plan and a rhythm — both
        are right here. Do the three things below today and you're officially on the path.
      </p>
    </div>
  </section>

  <!-- ── Pick your pace ───────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-vermilion-deep">Step 1 · Be honest about time</p>
      <h2 class="mt-2 text-balance text-3xl font-semibold tracking-tight sm:text-4xl">Pick your pace</h2>
      <p class="mt-3 text-pretty text-ink-2">
        The whole Year-1 foundation is about <strong>{totalFoundationHours} hours</strong>. How long
        that takes is entirely up to your weekly hours. Pick a row and commit to it.
      </p>
    </div>
    <dl class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
      {
        pace.map((p) => (
          <div
            class:list={[
              'rounded-[14px] border-2 border-ink p-5 text-center',
              p.featured ? 'bg-ink text-paper shadow-block' : 'bg-card shadow-block-sm',
            ]}
          >
            <dt class="font-mono text-xs uppercase tracking-wide" class:list={[p.featured ? 'text-honey' : 'text-ink-3']}>{p.label}</dt>
            <dd class="mt-2 font-display text-3xl font-semibold">{p.hoursPerWeek}<span class="ml-1 text-base font-normal" class:list={[p.featured ? 'text-paper/70' : 'text-ink-2']}>h/wk</span></dd>
            <dd class="mt-1 text-sm" class:list={[p.featured ? 'text-paper/80' : 'text-ink-2']}>{p.toGoPro} to go pro</dd>
            {p.featured && <dd class="mt-2 font-mono text-[0.62rem] uppercase tracking-wide text-honey">recommended</dd>}
          </div>
        ))
      }
    </dl>
  </section>

  <!-- ── Set up your workshop ─────────────────────────────────────────── -->
  <section class="border-y-2 border-ink bg-paper-2">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <div class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-vermilion-deep">Step 2 · Three free tools</p>
        <h2 class="mt-2 text-balance text-3xl font-semibold tracking-tight sm:text-4xl">Set up your workshop</h2>
        <p class="mt-3 text-pretty text-ink-2">
          Everything in this roadmap is free. These three tools are all you need to begin —
          Week 0 walks you through each one, step by step.
        </p>
      </div>
      <ul class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          setup.map((s) => (
            <li class="rounded-[14px] border-2 border-ink bg-card p-5 shadow-block-sm">
              <span class="text-2xl" aria-hidden="true">{s.icon}</span>
              <h3 class="mt-2 font-display text-lg font-semibold">{s.tool}</h3>
              <p class="mt-1 text-sm text-ink-2">{s.what}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ── First 3 actions ──────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-vermilion-deep">Step 3 · Do these today</p>
      <h2 class="mt-2 text-balance text-3xl font-semibold tracking-tight sm:text-4xl">Your first three actions</h2>
    </div>
    <ol class="mt-8 space-y-4">
      {
        firstActions.map((a, i) => (
          <li class="flex gap-4 rounded-[14px] border-2 border-ink bg-card p-5 shadow-block-sm sm:p-6">
            <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border-2 border-ink bg-paper-2 font-mono text-base font-bold">
              {i + 1}
            </span>
            <div class="min-w-0 flex-1">
              <h3 class="font-display text-lg font-semibold">{a.t}</h3>
              <p class="mt-1 text-pretty text-ink-2">{a.d}</p>
              {a.href && (
                <a href={a.href} class="mt-3 inline-flex items-center gap-1.5 font-semibold text-vermilion-deep underline-offset-4 hover:underline">
                  {a.cta} <span aria-hidden="true">→</span>
                </a>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- ── The daily loop ───────────────────────────────────────────────── -->
  <section class="border-y-2 border-ink bg-ink text-paper">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-honey">The rhythm that works</p>
        <h2 class="mt-2 text-balance text-3xl font-semibold tracking-tight text-paper sm:text-4xl">Every session, the same loop</h2>
        <p class="mt-3 text-pretty text-paper/80">
          The secret ingredient is <strong class="text-paper">build alone</strong>: you never just
          watch — you rebuild it yourself until it's truly yours. And once you have skills, every
          session ends with a step toward income.
        </p>
      </div>
      <ol class="mt-9 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          loop.map((step, i) => (
            <li class="relative rounded-[14px] border-2 border-paper/20 bg-paper/5 p-5">
              <span class="font-mono text-sm font-bold text-honey">{step.k}</span>
              <h3 class="mt-2 font-display text-xl font-semibold text-paper">{step.t}</h3>
              <p class="mt-2 text-sm text-paper/75">{step.d}</p>
              {i < loop.length - 1 && (
                <span class="absolute -right-3 top-1/2 z-10 hidden -translate-y-1/2 font-mono text-paper/40 lg:block" aria-hidden="true">→</span>
              )}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-6xl px-4 py-16 text-center sm:px-6">
    <h2 class="mx-auto max-w-2xl text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
      Workshop ready? Open Year 1.
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-pretty text-lg text-ink-2">
      Ten phases, in order, from your first line of HTML to your first paid invoice.
    </p>
    <a
      href="/v2"
      class="mt-7 inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-vermilion px-6 py-3.5 text-lg font-semibold text-white shadow-block transition-transform hover:-translate-y-0.5 active:translate-y-0 active:shadow-block-sm"
    >
      Open Year 1 — The Foundation <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
