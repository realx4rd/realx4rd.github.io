---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page doesn't exist — but the course does.">
  <section class="grid-paper flex min-h-[60vh] items-center border-b-2 border-ink">
    <div class="mx-auto max-w-xl px-4 py-20 text-center sm:px-6">
      <p class="font-mono text-7xl font-bold text-ink-3">404</p>
      <h1 class="mt-4 text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
        This page got lost in the build.
      </h1>
      <p class="mt-3 text-pretty text-ink-2">
        The link is broken or the page moved. No worries — let's get you back on the path.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/" class="inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-vermilion px-5 py-3 font-semibold text-white shadow-block-sm transition-transform hover:-translate-y-0.5">
          Go home
        </a>
        <a href="/roadmap" class="inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-card px-5 py-3 font-semibold shadow-block-sm transition-transform hover:-translate-y-0.5">
          See the roadmap
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
