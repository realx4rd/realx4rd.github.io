---
import BaseLayout from '../layouts/BaseLayout.astro';

const groups = [
  {
    name: 'HTML & CSS',
    blurb: 'The foundations — structure and style.',
    links: [
      { label: 'MDN Web Docs — the reference', url: 'https://developer.mozilla.org/en-US/docs/Learn_web_development' },
      { label: 'The Odin Project — Foundations', url: 'https://www.theodinproject.com/paths/foundations/courses/foundations' },
      { label: 'freeCodeCamp — Responsive Web Design', url: 'https://www.freecodecamp.org/learn/responsive-web-design-v9/' },
      { label: 'web.dev — Learn CSS', url: 'https://web.dev/learn/css' },
      { label: 'Flexbox Froggy (game)', url: 'https://flexboxfroggy.com/' },
      { label: 'CSS Grid Garden (game)', url: 'https://cssgridgarden.com/' },
    ],
  },
  {
    name: 'JavaScript',
    blurb: 'The biggest phase — take your time here.',
    links: [
      { label: 'MDN — JavaScript guide', url: 'https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide' },
      { label: 'javascript.info — The Modern JS Tutorial', url: 'https://javascript.info/' },
      { label: 'The Odin Project — JavaScript', url: 'https://www.theodinproject.com/paths/foundations/courses/foundations' },
      { label: 'freeCodeCamp — JavaScript', url: 'https://www.freecodecamp.org/learn/javascript-algorithms-and-data-structures-v8/' },
    ],
  },
  {
    name: 'Tailwind · Alpine · jQuery',
    blurb: 'The modern tooling layer.',
    links: [
      { label: 'Tailwind CSS — Docs', url: 'https://tailwindcss.com/docs' },
      { label: 'Tailwind CSS — Play CDN (zero setup)', url: 'https://tailwindcss.com/docs/installation/play-cdn' },
      { label: 'Alpine.js — Start Here', url: 'https://alpinejs.dev/start-here' },
      { label: 'jQuery — API reference (legacy literacy)', url: 'https://api.jquery.com/' },
    ],
  },
  {
    name: 'Tools & Git',
    blurb: 'Your workshop and your safety net.',
    links: [
      { label: 'VS Code — Getting Started', url: 'https://code.visualstudio.com/docs/introvideos/basics' },
      { label: 'Git — the simple guide', url: 'https://rogerdudler.github.io/git-guide/' },
      { label: 'GitHub Skills', url: 'https://skills.github.com/' },
      { label: 'Chrome DevTools — Docs', url: 'https://developer.chrome.com/docs/devtools/overview' },
    ],
  },
  {
    name: 'Learn how to learn (+ AI)',
    blurb: 'The meta-skills that outlast any framework.',
    links: [
      { label: 'MDN — Getting started (soft skills)', url: 'https://developer.mozilla.org/en-US/docs/Learn_web_development/Getting_started' },
      { label: 'freeCodeCamp — Escaping tutorial hell', url: 'https://www.freecodecamp.org/news/how-to-learn-from-coding-tutorials-and-avoid-tutorial-hell/' },
    ],
  },
  {
    name: 'Design · Accessibility · SEO · Performance',
    blurb: 'The pro-skills that make work look hireable.',
    links: [
      { label: 'Refactoring UI — design tips', url: 'https://www.refactoringui.com/' },
      { label: 'Google Fonts', url: 'https://fonts.google.com/' },
      { label: 'WebAIM — Contrast Checker', url: 'https://webaim.org/resources/contrastchecker/' },
      { label: 'The A11Y Project — Checklist', url: 'https://www.a11yproject.com/checklist/' },
      { label: 'The Open Graph protocol', url: 'https://ogp.me/' },
      { label: 'web.dev — Core Web Vitals', url: 'https://web.dev/articles/vitals' },
      { label: 'Squoosh — image compression', url: 'https://squoosh.app/' },
    ],
  },
  {
    name: 'Deploy & ship for free',
    blurb: 'Get your work on the real internet.',
    links: [
      { label: 'Vercel — Docs', url: 'https://vercel.com/docs' },
      { label: 'Netlify — Docs', url: 'https://docs.netlify.com/' },
      { label: 'GitHub Pages — Quickstart', url: 'https://docs.github.com/en/pages/quickstart' },
      { label: 'Cloudflare Pages — Docs', url: 'https://developers.cloudflare.com/pages/' },
    ],
  },
  {
    name: 'React & TypeScript',
    blurb: 'The industry-standard UI library and typed JavaScript.',
    links: [
      { label: 'React — Official docs (react.dev)', url: 'https://react.dev/learn' },
      { label: 'The Odin Project — React', url: 'https://www.theodinproject.com/paths/full-stack-javascript/courses/react' },
      { label: 'Scrimba — Learn React (free)', url: 'https://scrimba.com/learn/learnreact' },
      { label: 'TypeScript — Handbook', url: 'https://www.typescriptlang.org/docs/handbook/intro.html' },
    ],
  },
  {
    name: 'Backend, APIs & Databases',
    blurb: 'The server side — so you can ship full-stack products.',
    links: [
      { label: 'roadmap.sh — Backend Developer', url: 'https://roadmap.sh/backend' },
      { label: 'Node.js — Learn', url: 'https://nodejs.org/en/learn' },
      { label: 'MDN — Express/Node server-side', url: 'https://developer.mozilla.org/en-US/docs/Learn_web_development/Extensions/Server-side/Express_Nodejs' },
      { label: 'PostgreSQL Tutorial', url: 'https://www.postgresqltutorial.com/' },
      { label: 'Supabase — Docs', url: 'https://supabase.com/docs' },
    ],
  },
  {
    name: 'AI Engineering & Automation',
    blurb: 'The 2026 differentiator — build with LLMs and automate real work.',
    links: [
      { label: 'OpenAI — API quickstart', url: 'https://platform.openai.com/docs/quickstart' },
      { label: 'Anthropic — Claude docs', url: 'https://docs.anthropic.com/' },
      { label: 'Prompt Engineering Guide', url: 'https://www.promptingguide.ai/' },
      { label: 'n8n — Docs (automation)', url: 'https://docs.n8n.io/' },
      { label: 'Make — Help center', url: 'https://www.make.com/en/help/home' },
      { label: 'roadmap.sh — AI & Data Scientist', url: 'https://roadmap.sh/ai-data-scientist' },
    ],
  },
  {
    name: 'Freelancing & getting paid',
    blurb: 'Turn skills into income — the business half of the job.',
    links: [
      { label: 'Upwork — Freelancing resources', url: 'https://www.upwork.com/resources' },
      { label: 'freeCodeCamp — How to start freelancing', url: 'https://www.freecodecamp.org/news/how-to-start-freelancing/' },
      { label: 'Freelancers Union — Getting paid & contracts', url: 'https://blog.freelancersunion.org/' },
      { label: 'Contra — Commission-free freelancing', url: 'https://contra.com/' },
    ],
  },
];
---

<BaseLayout
  title="Resources"
  description="A curated library of the best free resources for the whole journey — HTML/CSS/JS, React, backend & databases, AI engineering & automation, design, deployment, and freelancing — MDN, The Odin Project, freeCodeCamp, roadmap.sh and official docs."
>
  <section class="grid-paper border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-vermilion-deep">Resources</p>
      <h1 class="mt-2 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">The best of the free web</h1>
      <p class="mt-4 max-w-2xl text-pretty text-lg text-ink-2">
        You don't need to buy anything to go from beginner to earning freelancer — the best
        material is free. This is our hand-picked shortlist across the whole path: web
        foundations, full-stack, AI engineering, and the business of freelancing. Every week and
        module page also links the exact resources for that topic.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        groups.map((g) => (
          <section class="rounded-[14px] border-2 border-ink bg-card p-6 shadow-block-sm">
            <h2 class="font-display text-xl font-semibold">{g.name}</h2>
            <p class="mt-1 text-sm text-ink-2">{g.blurb}</p>
            <ul class="mt-4 space-y-2.5">
              {g.links.map((l) => (
                <li>
                  <a href={l.url} target="_blank" rel="noopener noreferrer" class="group flex items-start gap-2 text-sm">
                    <span class="mt-0.5 text-vermilion" aria-hidden="true">↗</span>
                    <span class="underline-offset-4 group-hover:text-vermilion-deep group-hover:underline">{l.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <p class="mt-10 text-center font-mono text-sm text-ink-3">
      Found a great free resource? That's the spirit — keep a list of your own.
    </p>
  </div>
</BaseLayout>
