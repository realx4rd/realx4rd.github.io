---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TechBadge from '../components/TechBadge.astro';

const weeks = (await getCollection('weeks')).sort((a, b) => a.data.week - b.data.week);
const projects = weeks.filter((w) => w.data.project);
const label = (n: number) => (n === 0 ? 'Week 0' : `Week ${n}`);
---

<BaseLayout
  title="Assignments"
  description="How assignments work: a short daily build-it-yourself exercise every day, plus a build-from-scratch project you deploy every weekend. See every project you'll ship."
>
  <section class="grid-paper border-b-2 border-ink">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-vermilion-deep">Assignments</p>
      <h1 class="mt-2 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">You learn by shipping</h1>
      <p class="mt-4 max-w-2xl text-pretty text-lg text-ink-2">
        Two kinds of assignment, every week. Small reps daily to make concepts stick, and a
        real project each weekend that goes live on the internet and into your portfolio.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <!-- Two assignment types -->
    <section class="grid gap-5 sm:grid-cols-2">
      <div class="rounded-[14px] border-2 border-ink bg-card p-6 shadow-block-sm">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-vermilion-deep">Daily · ~35 min</span>
        <h2 class="mt-2 font-display text-2xl font-semibold">The “code-alone” rep</h2>
        <p class="mt-2 text-ink-2">
          After each guided demo, you rebuild the same idea from a blank page — a new prompt,
          no copying. It's the moment a concept goes from “makes sense” to “I can do this.”
        </p>
        <ul class="mt-4 space-y-2 text-sm">
          <li class="flex gap-2"><span class="text-teal-deep" aria-hidden="true">✓</span> One small, focused exercise</li>
          <li class="flex gap-2"><span class="text-teal-deep" aria-hidden="true">✓</span> Committed to GitHub the same day</li>
          <li class="flex gap-2"><span class="text-teal-deep" aria-hidden="true">✓</span> You can explain every line</li>
        </ul>
      </div>
      <div class="rounded-[14px] border-2 border-ink bg-ink p-6 text-paper shadow-block-sm">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-honey">Weekly · ~3 hrs</span>
        <h2 class="mt-2 font-display text-2xl font-semibold text-paper">The weekend project</h2>
        <p class="mt-2 text-paper/80">
          A build-from-scratch project that combines everything from the week — then you
          deploy it live and add it to your growing portfolio.
        </p>
        <p class="mt-4 font-mono text-xs uppercase tracking-[0.2em] text-paper/60">Reviewed against a 3-part rubric</p>
        <div class="mt-2 flex flex-wrap gap-2">
          <span class="rounded-md border border-paper/25 bg-paper/10 px-2.5 py-1 text-xs">Does it work?</span>
          <span class="rounded-md border border-paper/25 bg-paper/10 px-2.5 py-1 text-xs">Is it accessible?</span>
          <span class="rounded-md border border-paper/25 bg-paper/10 px-2.5 py-1 text-xs">Is it not ugly?</span>
        </div>
      </div>
    </section>

    <!-- Project gallery -->
    <section class="mt-16">
      <h2 class="font-display text-3xl font-semibold tracking-tight">Everything you'll ship</h2>
      <p class="mt-2 text-ink-2">Twelve deployed builds, from a hand-coded bio page to a full interactive capstone.</p>
      <ol class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          projects.map((w) => (
            <li>
              <a
                href={`/weeks/${w.data.week}`}
                class="group flex h-full flex-col rounded-[14px] border-2 border-ink bg-card p-5 shadow-block-sm transition-transform hover:-translate-y-0.5"
              >
                <div class="flex items-center justify-between gap-2">
                  <span class="font-mono text-xs font-bold text-ink-3">{label(w.data.week)}</span>
                  {w.data.milestone && <span class="rounded-full border-2 border-ink bg-honey px-2 py-0.5 font-mono text-[0.6rem] font-bold">★</span>}
                </div>
                <h3 class="mt-2 font-display text-lg font-semibold group-hover:text-vermilion-deep">{w.data.project!.title}</h3>
                <p class="mt-1 flex-1 text-sm text-ink-2">{w.data.project!.brief}</p>
                <div class="mt-3 flex flex-wrap items-center gap-1.5">
                  {w.data.tech.map((t) => (
                    <TechBadge tech={t} />
                  ))}
                  {w.data.project!.deploy && <span class="font-mono text-[0.62rem] text-ink-3">⬆ {w.data.project!.deploy}</span>}
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </section>

    <div class="mt-14 rounded-[14px] border-2 border-ink bg-paper-2 p-7 text-center shadow-block-sm">
      <h2 class="font-display text-2xl font-semibold">Your portfolio starts in Week 1.</h2>
      <p class="mx-auto mt-2 max-w-md text-ink-2">Each project is a real, shareable URL. By the end you have a body of work, not just a certificate.</p>
      <a href="/roadmap" class="mt-5 inline-flex items-center gap-2 rounded-xl border-2 border-ink bg-vermilion px-5 py-3 font-semibold text-white shadow-block-sm transition-transform hover:-translate-y-0.5">
        Browse the roadmap <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</BaseLayout>
